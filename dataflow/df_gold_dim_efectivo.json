{
	"name": "df_gold_dim_efectivo",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_efectivos",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "silver_especialidades",
						"type": "DatasetReference"
					},
					"name": "source2"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_efectivo",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_efectivo as integer,",
				"          id_especialidad as integer,",
				"          id_unidad_actual as integer,",
				"          id_rango_actual as integer,",
				"          nombre as string,",
				"          ci as string,",
				"          fecha_nacimiento as date,",
				"          genero as string,",
				"          departamento_origen as string,",
				"          fecha_ingreso as date,",
				"          estado as string,",
				"          salario_mensual as decimal(18,2)",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source(output(",
				"          id_especialidad as integer,",
				"          nombre as string,",
				"          area as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source2",
				"source1, source2 join(source1@id_especialidad == source2@id_especialidad,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1 select(mapColumn(",
				"          id_efectivo,",
				"          ci,",
				"          nombre_completo = source1@nombre,",
				"          genero,",
				"          departamento_origen,",
				"          fecha_ingreso,",
				"          nombre_especialidad = source2@nombre,",
				"          area_especialidad = area",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          efectivo_key as integer,",
				"          id_efectivo as integer,",
				"          ci as string,",
				"          nombre_completo as string,",
				"          genero as string,",
				"          departamento_origen as string,",
				"          fecha_ingreso as date,",
				"          nombre_especialidad as string,",
				"          area_especialidad as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_efectivo,",
				"          ci,",
				"          nombre_completo,",
				"          genero,",
				"          departamento_origen,",
				"          fecha_ingreso,",
				"          nombre_especialidad,",
				"          area_especialidad",
				"     )) ~> sink1"
			]
		}
	}
}
