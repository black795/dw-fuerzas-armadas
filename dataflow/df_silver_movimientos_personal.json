{
	"name": "df_silver_movimientos_personal",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronce_movimientos_personal_destino",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_movimientos_personal",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "filter1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_movimiento as string,",
				"          id_efectivo as string,",
				"          id_unidad_destino as string,",
				"          id_rango as string,",
				"          id_tipo as string,",
				"          fecha_movimiento as string,",
				"          antiguedad_anios as string,",
				"          salario_mensual as string,",
				"          observaciones as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\n    TRIM(id_movimiento) AS id_movimiento,\\n    TRIM(id_efectivo) AS id_efectivo,\\n    TRIM(id_unidad_destino) AS id_unidad_destino,\\n    TRIM(id_rango) AS id_rango,\\n    TRIM(id_tipo) AS id_tipo,\\n    TRIM(fecha_movimiento) AS fecha_movimiento,\\n    TRIM(antiguedad_anios) AS antiguedad_anios,\\n    TRIM(salario_mensual) AS salario_mensual,\\n    TRIM(observaciones) AS observaciones\\nFROM bronze.movimientos_personal_raw',",
				"     format: 'query') ~> source1",
				"source1 filter(!isNull(id_movimiento) && length(trim(id_movimiento)) > 0 && !isNull(id_efectivo) && length(trim(id_efectivo)) > 0) ~> filter1",
				"filter1 derive(fecha_movimiento = coalesce(     toDate(fecha_movimiento, 'yyyy/MM/dd'),     toDate(fecha_movimiento, 'dd-MM-yyyy'),     toDate(fecha_movimiento, 'MM-dd-yyyy'),     toDate(fecha_movimiento, 'dd/MM/yyyy'),     toDate(fecha_movimiento, 'yyyyMMdd') ),",
				"          antiguedad_anios = case(     in(['0 a.', '0', 'cero años', '0,0 años'], lower(trim(antiguedad_anios))), '0',     in(['3 años', '3 a.'], lower(trim(antiguedad_anios))), '3',     lower(trim(antiguedad_anios)) == '4,0 años', '4',     lower(trim(antiguedad_anios)) == 'siete', '7',     lower(trim(antiguedad_anios)) == 'once años', '11',     in(['aprox. 12', 'doce años'], lower(trim(antiguedad_anios))), '12',     lower(trim(antiguedad_anios)) == 'trece años', '13',     lower(trim(antiguedad_anios)) == 'aprox. 14', '14',     in(['15.5 años', 'quince'], lower(trim(antiguedad_anios))), '15',     lower(trim(antiguedad_anios)) == 'diecisiete', '17',     lower(trim(antiguedad_anios)) == 'veintidós', '22',     regexReplace(antiguedad_anios, '[^0-9]', '') ),",
				"          salario_mensual = iif(instr(regexReplace(lower(salario_mensual), '[^0-9.,]', ''), '.') < instr(regexReplace(lower(salario_mensual), '[^0-9.,]', ''), ','),     replace(replace(regexReplace(lower(salario_mensual), '[^0-9.,]', ''), '.', ''), ',', '.'),     replace(regexReplace(lower(salario_mensual), '[^0-9.,]', ''), ',', '') ),",
				"          observaciones = iif(in(['null', ''], lower(trim(observaciones))), toString(null()), initCap(regexReplace(replace(observaciones, '\\t', ' '), '\\\\s+', ' ')))) ~> derivedColumn1",
				"derivedColumn1 derive(id_movimiento = toInteger(id_movimiento),",
				"          id_rango = toInteger(id_rango),",
				"          id_unidad_destino = toInteger(id_unidad_destino),",
				"          id_tipo = toInteger(id_tipo),",
				"          antiguedad_anios = toInteger(antiguedad_anios),",
				"          salario_mensual = toDecimal(salario_mensual, 18, 2),",
				"          id_efectivo = toInteger(id_efectivo)) ~> derivedColumn2",
				"derivedColumn2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_movimiento as integer,",
				"          id_efectivo as integer,",
				"          id_unidad_destino as integer,",
				"          id_rango as integer,",
				"          id_tipo as integer,",
				"          fecha_movimiento as date,",
				"          antiguedad_anios as integer,",
				"          salario_mensual as decimal(18,2),",
				"          observaciones as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_movimiento,",
				"          id_efectivo,",
				"          id_unidad_destino,",
				"          id_rango,",
				"          id_tipo,",
				"          fecha_movimiento,",
				"          antiguedad_anios,",
				"          salario_mensual,",
				"          observaciones",
				"     )) ~> sink1"
			]
		}
	}
}