{
	"name": "df_gold_dim_zona_operacion",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_zonas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_zona_operacion",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_zona as integer,",
				"          nombre as string,",
				"          departamento as string,",
				"          frontera_con as string,",
				"          tipo_terreno as string,",
				"          altitud_msnm as integer,",
				"          nivel_riesgo as string,",
				"          acceso_carretero as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 select(mapColumn(",
				"          id_zona,",
				"          nombre_zona = nombre,",
				"          departamento,",
				"          frontera_con,",
				"          tipo_terreno,",
				"          nivel_riesgo",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          zona_key as integer,",
				"          id_zona as integer,",
				"          nombre_zona as string,",
				"          departamento as string,",
				"          frontera_con as string,",
				"          tipo_terreno as string,",
				"          nivel_riesgo as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_zona,",
				"          nombre_zona,",
				"          departamento,",
				"          frontera_con,",
				"          tipo_terreno,",
				"          nivel_riesgo",
				"     )) ~> sink1"
			]
		}
	}
}
