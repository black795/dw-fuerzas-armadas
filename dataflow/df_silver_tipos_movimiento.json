{
	"name": "df_silver_tipos_movimiento",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronce_tipos_movimiento_destino",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_tipos_movimiento",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          id_tipo as integer,",
				"          nombre as string,",
				"          descripcion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\r\\n    TRIM(id_tipo) AS id_tipo,\\r\\n    TRIM(nombre) AS nombre,\\r\\n    TRIM(descripcion) AS descripcion\\r\\nFROM bronze.tipos_movimiento_raw',",
				"     format: 'query') ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_tipo as integer,",
				"          nombre as string,",
				"          descripcion as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_tipo,",
				"          nombre,",
				"          descripcion",
				"     )) ~> sink1"
			]
		}
	}
}