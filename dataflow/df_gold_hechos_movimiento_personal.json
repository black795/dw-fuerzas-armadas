{
	"name": "df_gold_hechos_movimiento_personal",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_movimientos_personal",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_efectivo",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_unidad",
						"type": "DatasetReference"
					},
					"name": "source3"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_rango",
						"type": "DatasetReference"
					},
					"name": "source4"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_tipo_movimiento",
						"type": "DatasetReference"
					},
					"name": "source5"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_hechos_movimiento_personal",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "join2"
				},
				{
					"name": "join3"
				},
				{
					"name": "join4"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_movimiento as integer,",
				"          id_efectivo as integer,",
				"          id_unidad_destino as integer,",
				"          id_rango as integer,",
				"          id_tipo as integer,",
				"          fecha_movimiento as date,",
				"          antiguedad_anios as integer,",
				"          salario_mensual as decimal(18,2),",
				"          observaciones as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source(output(",
				"          efectivo_key as integer,",
				"          id_efectivo as integer,",
				"          ci as string,",
				"          nombre_completo as string,",
				"          genero as string,",
				"          departamento_origen as string,",
				"          fecha_ingreso as date,",
				"          nombre_especialidad as string,",
				"          area_especialidad as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source2",
				"source(output(",
				"          unidad_key as integer,",
				"          id_unidad as integer,",
				"          nombre_unidad as string,",
				"          codigo_unidad as string,",
				"          ciudad as string,",
				"          departamento as string,",
				"          tipo_cuartel as string,",
				"          nombre_brigada as string,",
				"          nivel_jerarquico as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source3",
				"source(output(",
				"          rango_key as integer,",
				"          id_rango as integer,",
				"          nombre_rango as string,",
				"          categoria as string,",
				"          nivel_jerarquico as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source4",
				"source(output(",
				"          tipo_movimiento_key as integer,",
				"          id_tipo as integer,",
				"          nombre_tipo as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source5",
				"source1, source2 join(source1@id_efectivo == source2@id_efectivo,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1, source3 join(id_unidad_destino == id_unidad,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"join2, source4 join(id_rango == {id_rango},",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join3",
				"join3, source5 join(id_tipo == {id_tipo},",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join4",
				"join4 derive(fecha_movimiento_key = toInteger(toString(fecha_movimiento, 'yyyyMMdd'))) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          fecha_movimiento_key,",
				"          efectivo_key,",
				"          unidad_destino_key = unidad_key,",
				"          rango_key,",
				"          tipo_movimiento_key,",
				"          antiguedad_anios,",
				"          salario_mensual",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          hecho_movimiento_key as integer,",
				"          fecha_movimiento_key as integer,",
				"          efectivo_key as integer,",
				"          unidad_destino_key as integer,",
				"          rango_key as integer,",
				"          tipo_movimiento_key as integer,",
				"          antiguedad_anios as integer,",
				"          salario_mensual as decimal(18,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          fecha_movimiento_key,",
				"          efectivo_key,",
				"          unidad_destino_key,",
				"          rango_key,",
				"          tipo_movimiento_key,",
				"          antiguedad_anios,",
				"          salario_mensual",
				"     )) ~> sink1"
			]
		}
	}
}
