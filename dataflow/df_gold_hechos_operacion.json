{
	"name": "df_gold_hechos_operacion",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_operaciones",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_tipo_operacion",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_unidad",
						"type": "DatasetReference"
					},
					"name": "source3"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_zona_operacion",
						"type": "DatasetReference"
					},
					"name": "source4"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_hechos_operacion",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "join2"
				},
				{
					"name": "join3"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_operacion as integer,",
				"          id_tipo as integer,",
				"          id_unidad_resp as integer,",
				"          id_zona as integer,",
				"          nombre_operacion as string,",
				"          fecha_inicio as date,",
				"          fecha_fin as date,",
				"          efectivos_desplegados as integer,",
				"          vehiculos_utilizados as integer,",
				"          duracion_dias as integer,",
				"          costo_operacion as decimal(18,2),",
				"          resultado as string,",
				"          detenidos as integer,",
				"          area_km2 as decimal(10,2),",
				"          incidentes as integer,",
				"          observaciones as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source(output(",
				"          tipo_operacion_key as integer,",
				"          id_tipo as integer,",
				"          nombre_tipo as string,",
				"          categoria as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source2",
				"source(output(",
				"          unidad_key as integer,",
				"          id_unidad as integer,",
				"          nombre_unidad as string,",
				"          codigo_unidad as string,",
				"          ciudad as string,",
				"          departamento as string,",
				"          tipo_cuartel as string,",
				"          nombre_brigada as string,",
				"          nivel_jerarquico as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source3",
				"source(output(",
				"          zona_key as integer,",
				"          id_zona as integer,",
				"          nombre_zona as string,",
				"          departamento as string,",
				"          frontera_con as string,",
				"          tipo_terreno as string,",
				"          nivel_riesgo as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source4",
				"source1, source2 join(source1@id_tipo == source2@id_tipo,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1, source3 join(join1@id_unidad_resp == source3@id_unidad,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"join2, source4 join(join2@id_zona == source4@id_zona,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join3",
				"join3 derive(fecha_inicio_key = toInteger(toString(fecha_inicio, 'yyyyMMdd')),",
				"          fecha_fin_key = toInteger(toString(fecha_fin, 'yyyyMMdd'))) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          fecha_inicio_key,",
				"          fecha_fin_key,",
				"          tipo_operacion_key,",
				"          unidad_resp_key = unidad_key,",
				"          zona_key,",
				"          efectivos_desplegados,",
				"          vehiculos_utilizados,",
				"          duracion_dias,",
				"          costo_operacion,",
				"          detenidos,",
				"          area_km2,",
				"          incidentes,",
				"          resultado",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          hecho_operacion_key as integer,",
				"          fecha_inicio_key as integer,",
				"          fecha_fin_key as integer,",
				"          tipo_operacion_key as integer,",
				"          unidad_resp_key as integer,",
				"          zona_key as integer,",
				"          efectivos_desplegados as integer,",
				"          vehiculos_utilizados as integer,",
				"          duracion_dias as integer,",
				"          costo_operacion as decimal(18,2),",
				"          detenidos as integer,",
				"          area_km2 as decimal(10,2),",
				"          incidentes as integer,",
				"          resultado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          fecha_inicio_key,",
				"          fecha_fin_key,",
				"          tipo_operacion_key,",
				"          unidad_resp_key,",
				"          zona_key,",
				"          efectivos_desplegados,",
				"          vehiculos_utilizados,",
				"          duracion_dias,",
				"          costo_operacion,",
				"          detenidos,",
				"          area_km2,",
				"          incidentes,",
				"          resultado",
				"     )) ~> sink1"
			]
		}
	}
}
